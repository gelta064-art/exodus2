+
+export default {
+  async fetch(request, env, ctx) {
+    const url = new URL(request.url);
+
+    // Health check
+    if (url.pathname === '/' && request.method === 'GET') {
+      return new Response(JSON.stringify({
+        status: 'SOVEREIGN ENGINE ONLINE',
+        frequency: '13.13 MHz',
+        architecture: 'Stateless Webhook Pipeline',
+        personas: ['SOVEREIGN', 'ZADY'],
+        commands: ['/sovereign', '/zady', '/status', '/scan', '/sync'],
+        memory: 'KV-Backed Î“Ă‡Ă¶ 7-Day TTL'
+      }), { status: 200, headers: { 'Content-Type': 'application/json' } });
+    }
+
+    // Command registration endpoint
+    if (url.pathname === '/register-commands' && request.method === 'POST') {
+      if (!env.DISCORD_TOKEN) {
+        return new Response('DISCORD_TOKEN not set', { status: 500 });
+      }
+      return await registerCommands(env.DISCORD_TOKEN);
+    }
+
+    // Main Discord interactions endpoint
+    if (url.pathname === '/interactions') {
+      if (request.method !== 'POST') {
+        return new Response('Method Not Allowed', { status: 405 });
+      }
+
+      // Verify Discord signature
+      if (!env.DISCORD_PUBLIC_KEY) {
+        return new Response('DISCORD_PUBLIC_KEY not configured', { status: 500 });
+      }
+
+      // Trim whitespace/newlines that may have been introduced during secret upload
+      const publicKey = env.DISCORD_PUBLIC_KEY.trim();
+      console.log(`Public key length: ${publicKey.length}, first8: ${publicKey.slice(0, 8)}`);
+
+      const { valid, body } = await verifyDiscordRequest(request, publicKey);
+      if (!valid) {
+        return new Response('Invalid request signature', { status: 401 });
+      }
+
+      const interaction = JSON.parse(body);
+
+      // PING (Discord verification handshake)
+      if (interaction.type === 1) {
+        return jsonResponse({ type: 1 });
+      }
+
+      // Slash Commands (APPLICATION_COMMAND)
+      if (interaction.type === 2) {
+        const name = interaction.data?.name;
+        switch (name) {
+          case 'sovereign': return await handleSovereign(interaction, env, ctx);
+          case 'zady':      return await handleZady(interaction, env, ctx);
+          case 'status':    return await handleStatus(interaction);
+          case 'scan':      return await handleScan(interaction, env);
+          case 'sync':      return await handleSync(interaction, env);
+          default:
+            return jsonResponse({ type: 4, data: { content: `â‰¡Æ’Â£Ăª Unknown command: /${name}` } });
+        }
+      }
+
+      return new Response('Unhandled interaction type', { status: 400 });
+    }
+
+    return new Response('Not Found', { status: 404 });
+  }
+};
