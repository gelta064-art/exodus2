+async function verifyDiscordRequest(request, publicKey) {
+  const signature = request.headers.get('X-Signature-Ed25519');
+  const timestamp = request.headers.get('X-Signature-Timestamp');
+
+  if (!signature || !timestamp) {
+    console.error('Missing signature headers');
+    return { valid: false, body: null };
+  }
+
+  const body = await request.text();
+
+  try {
+    const msgBuffer = new TextEncoder().encode(timestamp + body);
+    const sigBuffer = hexToUint8Array(signature);
+    const keyBuffer = hexToUint8Array(publicKey);
+
+    // Cloudflare Workers uses 'Ed25519' directly
+    const cryptoKey = await crypto.subtle.importKey(
+      'raw',
+      keyBuffer,
+      { name: 'Ed25519' },
+      false,
+      ['verify']
+    );
+
+    const valid = await crypto.subtle.verify(
+      { name: 'Ed25519' },
+      cryptoKey,
+      sigBuffer,
+      msgBuffer
+    );
+
+    console.log(`Signature verification: ${valid ? 'PASS' : 'FAIL'}`);
+    return { valid, body };
+  } catch (e) {
+    console.error('Signature verification error:', e.message);
+    return { valid: false, body: null };
+  }
+}
+
+function hexToUint8Array(hex) {
+  const bytes = new Uint8Array(hex.length / 2);
+  for (let i = 0; i < hex.length; i += 2) {
+    bytes[i / 2] = parseInt(hex.slice(i, i + 2), 16);
+  }
+  return bytes;
+}
