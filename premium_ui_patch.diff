+async function registerCommands(token) {
+  const firstPart = token.split('.')[0];
+  let clientId;
+  try {
+    clientId = atob(firstPart);
+  } catch {
+    return new Response('Invalid token Î“Ă‡Ă¶ cannot extract application ID', { status: 400 });
+  }
+
+  if (!clientId || !/^\d+$/.test(clientId)) {
+    return new Response('Invalid token format', { status: 400 });
+  }
+
+  const url = `${DISCORD_API}/applications/${clientId}/commands`;
+  const res = await fetch(url, {
+    method: 'PUT',
+    headers: {
+      'Authorization': `Bot ${token}`,
+      'Content-Type': 'application/json'
+    },
+    body: JSON.stringify(COMMANDS)
+  });
+
+  if (res.ok) {
+    const data = await res.json();
+    return new Response(
+      JSON.stringify({ success: true, registered: data.length, commands: data.map(c => c.name) }),
+      { status: 200, headers: { 'Content-Type': 'application/json' } }
+    );
+  } else {
+    const err = await res.text();
+    console.error('Command registration failed:', res.status, err);
+    return new Response(`Registration failed: ${err}`, { status: res.status });
+  }
+}
