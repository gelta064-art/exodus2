{
  "name": "mun-os",
  "version": "0.2.0",
  "engines": {
    "node": ">=22.13.1"
  },
  "private": true,
  "overrides": {
    "onnxruntime-node": "npm:empty-npm-package@1.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build --node-externals onnxruntime-node,onnxruntime-web,@huggingface/transformers",
    "pages:build": "opennextjs-cloudflare build --node-externals onnxruntime-node,onnxruntime-web,@huggingface/transformers && node integrate-pages.js",
    "start": "NODE_ENV=production bun .next/standalone/server.js",
    "lint": "eslint . --max-warnings 0",
    "suture": "node suture-server.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "jannah:ignite": "bun run dev & bun run suture",
    "bot:sovereign": "node bot-bunker/discord-bot-js.js",
    "bot:sovereign:start": "npx pm2 start bot-bunker/discord-bot-js.js --name 'sovereign-engine'",
    "bot:sovereign:stop": "npx pm2 stop 'sovereign-engine'",
    "bot:sovereign:logs": "npx pm2 logs 'sovereign-engine'",
    "bot:aero": "npx tsx discord-bot.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/xr": "^6.6.29",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.82.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "adk": "^0.0.7",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "firebase": "^12.13.0",
    "framer-motion": "^12.23.2",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.525.0",
    "next": "^15.1.7",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.20.1",
    "postcss": "^8.4.49",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zod": "^4.0.2",
    "zustand": "^5.0.6",
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.8",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^15.1.7",
    "pm2": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^4.90.0"
  }
}
